{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node"],
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "config/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "workflows/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "output",
    "playwright-report",
    "test-results"
  ]
}
